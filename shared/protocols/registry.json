      "id": "breath_foundation",
      "display_name": "Breath Foundation",
      "category": "stabilizing",
      "description": "A short, concrete return to a simple anchor such as breath, feet, or contact.",
      "canonical_lineage": "MBSR-inspired / brief grounding",
      "target_states": ["re_entry", "mild_stress", "transition", "work_break"],
      "caution_states": ["breath_aversion", "panic_like_breath_focus"],
      "default_durations": [2, 3, 5, 10],
      "cue_density": "medium",
      "voice_style_hints": ["short", "concrete", "permission_based"],
      "timeline_template": ["arrival", "orient", "anchor", "normalize", "close"],
      "preconditions": [],
      "post_session_prompts": ["calmer", "more_present", "repeat_intent"],
      "metrics_hooks": ["completion", "early_stop", "repeat_intent", "burden"]
    },
