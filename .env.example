# LLMプロバイダ ("openai" | "claude")
LLM_PROVIDER=openai

# 認証
# AUTH_MODE: "cognito" | "disabled"
AUTH_MODE=disabled
COGNITO_REGION=ap-northeast-1
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-cognito-client-id
DEV_AUTH_SUB=local-dev-user
DEV_AUTH_EMAIL=local@example.com

# Frontend auth (Vite)
# VITE_AUTH_MODE: "cognito" | "disabled"
VITE_AUTH_MODE=disabled
VITE_COGNITO_DOMAIN=https://your-domain.auth.ap-northeast-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your-cognito-client-id
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/

# OpenAI (data shares枠で無料)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Claude (代替)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ElevenLabs TTS
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Turso (SQLite over HTTP)
TURSO_URL=libsql://your-db.turso.io
TURSO_TOKEN=your-token

# サーバーアドレス
LISTEN_ADDR=0.0.0.0:3001
